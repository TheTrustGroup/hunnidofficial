# Copy to .env and fill in real values. Never commit .env — it is in .gitignore.

# Supabase (required for API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: used as fallback if above are unset
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Dev/staging only: set to "true" to allow manual sale fallback when record_sale RPC is missing
# ALLOW_SALE_FALLBACK=
